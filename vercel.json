{
  "version": 2,
  "functions": {
    "api/bot.py": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/index.py": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/bot",
      "dest": "/api/bot.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
