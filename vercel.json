{
  "version": 2,
  "builds": [
    {
      "src": "api/bot.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/admin.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/bot",
      "dest": "/api/bot.py"
    },
    {
      "src": "/admin",
      "dest": "/api/admin.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ],
  "env": {
    "PYTHONIOENCODING": "utf-8"
  }
}
